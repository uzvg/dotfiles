# vim:et sts=2 sw=2 ft=zsh

# Print functions
# _show_correct
# _show_tip
# _show_warning
# _show_error

emulate -L zsh
# set -x
setopt err_return no_unset pipe_fail

typeset key_name target_key_file identity_file decrypted_text

key_name=$1
target_key_file="$(chezmoi source-path)/secrets/keys/${key_name}.txt.age"
identity_file="$HOME/.config/chezmoi/key.txt"

# 参数检查
if (( $# != 1 )); then
  _show_error "参数错误。"
  _show_tip "正确格式：czm_decryptier key_name"
  return 1
fi

# 文件存在检查
if [[ ! -f "$target_key_file" ]]; then
  _show_error "秘钥文件不存在：$target_key_file"
  return 1
fi

# identity 文件检查
if [[ ! -f "$identity_file" ]]; then
  _show_error "identity 文件不存在：$identity_file"
  _show_tip "请确认 age 私钥路径是否正确"
  return 1
fi

# 解密
if decrypted_text=$(age --decrypt -i "$identity_file" "$target_key_file"); then
  _show_correct "解密成功"
  _show_tip '"$decrypted_text"'
else
  _show_error "解密失败"
  return 1
fi
