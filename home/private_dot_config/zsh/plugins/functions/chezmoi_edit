# vim:et sts=2 sw=2 ft=zsh

# Edit config file with `chezmoi edit`
chezmoi_edit() {
  emulate -L zsh
  setopt err_return no_unset pipe_fail

  local config_file=${1:?missing config file}

  if [[ ! -f $config_file ]]; then
    _zlog error "$config_file does not exist"
    return 1
  fi
  
  $commands[chezmoi] status $config_file &> /dev/null || {
    _zlog error "$config_file was not managed by chezmoi"
    _zlog info "You can add it with 'chezmoi add $config_file'"
    return 1
  }

  if ! $commands[chezmoi] edit --apply -- "$config_file"; then
    _zlog error "Failed to edit ${config_file:t} with chezmoi"
    return 1
  fi

  if [[ -N $config_file ]]; then
    _zlog info "${config_file:t} changed, restarting shell"
    exec $commands[zsh]
  else
    _zlog info "No changes detected in ${config_file:t}"
  fi
}
