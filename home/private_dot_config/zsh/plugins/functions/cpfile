# vim:et sts=2 sw=2 ft=zsh

# _zlog success
# _zlog info
# _zlog warn
# _zlog error

# Copy file into the clipboard
function cpfile () {
  emulate -L zsh
  setopt err_return no_unset pipe_fail

  # 验证参数并赋值
  (( # == 1 )) && {
    local file="$1"
  } || {
    _zlog error "Wrong parameters"
    _zlog info "Usage: cpfile <filename>"
    return 1
  } 

  [[ -f "$file" ]] || {
    _zlog error "${file:t} is not a valid file"
    return 1
  }

  case $XDG_SESSION_TYPE in
    (wayland)
      if (( ! ${+commands[wl-copy]} )); then {
        _zlog error "wl-copy command was not found"
        _zlog info "Install the wl-clipboard to resolve this"
        return 1
      }
      fi
			wl-copy < "${file}" || {
        _zlog error "Failed to copy using wl-copy"
        return 1
      } 
      ;;
    (xorg)
      if (( ! ${+commands[xclip]} )); then {
        _zlog error "xclip command was not found"
        _zlog info "Install the xclip to resolve this"
        return 1
      }
      fi
      xclip -selection clipboard -in < "${file}" || {
        _zlog error "Failed to copy using xclip"
        return 1
      } 
      ;;
    (*)
      _zlog error "Unsupported display server: $XDG_SESSION_TYPE"
      return 1
      ;;
  esac
  _zlog success "File copied to clipboard successfully"
}
